# Copy this file to .env and fill in values before running the server.
# .env is git-ignored and must never be committed.

# Flask secret key — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-generate-a-real-secret

# Allowed CORS origins (comma-separated). Use * only for local dev.
# Example for prod: https://yourdomain.com
CORS_ORIGINS=*

# Server bind settings
HOST=127.0.0.1
PORT=5001

# Set to 1 to enable Werkzeug dev server (local only, never in prod)
ALLOW_WERKZEUG=1
